<%- include('header') %>

    <div class="suggestion-container">
        <div class="suggestion-filters">
            <h2>Find Your Next Meal</h2>
            <div class="filters-form">
                <div class="form-group">
                    <label for="difficulty-filter">Difficulty:</label>
                    <select id="difficulty-filter">
                        <option value="">All Difficulties</option>
                        <option value="Easy">Easy</option>
                        <option value="Medium">Medium</option>
                        <option value="Hard">Hard</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="time-filter">Max Time (minutes):</label>
                    <input type="number" id="time-filter" min="0" placeholder="Leave empty for no limit">
                </div>
                <button onclick="getSuggestion()" class="btn btn-primary">Get Suggestion</button>
            </div>
        </div>

        <div id="suggestion-display" class="suggestion-display">
            <p>Click "Get Suggestion" to start!</p>
        </div>

        <div id="suggestion-history" class="suggestion-history">
            <h3>Suggestion History</h3>
            <div id="history-list" class="history-list">
                <p>No suggestions yet</p>
            </div>
        </div>

        <a href="/dashboard" class="btn btn-secondary">Back to Dashboard</a>
    </div>

    <!-- Modal for all recipes seen -->
    <div id="allSeenModal" class="modal" style="display: none;">
        <div class="modal-content">
            <h2>You've seen all recipes!</h2>
            <p>You've already seen all recipes that match your filters. Would you like to continue and see them again?
            </p>
            <div class="modal-actions">
                <button onclick="continueSuggestions()" class="btn btn-primary">Continue</button>
                <button onclick="closeModal()" class="btn btn-secondary">Cancel</button>
            </div>
        </div>
    </div>

    <script src="/js/suggestion.js"></script>

    <%- include('footer') %>