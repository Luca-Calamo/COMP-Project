<%- include('header') %>

    <div class="dashboard-container">
        <div class="dashboard-header">
            <h1>Your Recipes</h1>
            <a href="/recipe/add" class="btn btn-primary">+ Add New Recipe</a>
        </div>

        <% if (typeof message !=='undefined' && message) { %>
            <div class="alert alert-info">
                <%= message %>
            </div>
            <% } %>

                <div class="recipes-grid">
                    <% if (recipes && recipes.length> 0) { %>
                        <% recipes.forEach(recipe=> { %>
                            <div class="recipe-card" style="cursor: pointer;"
                                onclick="window.location.href='/recipe/<%= recipe.id %>'">
                                <div class="recipe-header">
                                    <h3>
                                        <%= recipe.name %>
                                    </h3>
                                    <span class="difficulty-badge difficulty-<%= recipe.difficulty.toLowerCase() %>">
                                        <%= recipe.difficulty %>
                                    </span>
                                </div>
                                <div class="recipe-meta">
                                    <span>⏱️ <%= recipe.total_time %> min</span>
                                    <span>👥 Serves <%= recipe.serves %></span>
                                </div>
                                <div class="recipe-actions">
                                    <a href="/recipe/edit/<%= recipe.id %>" class="btn btn-small btn-warning"
                                        onclick="event.stopPropagation();">Edit</a>
                                    <button class="btn btn-small btn-danger"
                                        onclick="event.stopPropagation(); deleteRecipe(<%= recipe.id %>)">Delete</button>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <div class="empty-state">
                                        <p>No recipes yet. <a href="/recipe/add">Create your first recipe!</a></p>
                                    </div>
                                    <% } %>
                </div>
    </div>

    <script src="/js/dashboard.js"></script>

    <%- include('footer') %>